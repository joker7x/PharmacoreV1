{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A community post created by a user.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "userId", "createdAt"]
    },
    "StockItem": {
      "title": "StockItem",
      "description": "An inventory item owned by a user.",
      "type": "object",
      "properties": {
        "name_en": { "type": "string" },
        "name_ar": { "type": "string" },
        "quantity": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["name_en", "name_ar", "quantity", "userId"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "User posts collection."
    },
    "/stock/{itemId}": {
      "schema": "StockItem",
      "description": "User stock items collection."
    }
  }
}
